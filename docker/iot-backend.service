[Unit]
Description=IoT Backend Docker Stack
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/home/backend-server/API-Rpi16GB/docker
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=120
User=backend-server

[Install]
WantedBy=multi-user.target
