{
  "uid": "actuator",
  "title": "Actuator (controller.py)",
  "description": "Counters exposed by controller.py via prometheus_client on :8000/metrics. Queue depth tracks the sensor pair buffer (typically 0 or 1, spikes mean the broker delivered half a pair without the other half within the freshness window).",
  "tags": ["actuator", "controller"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Queue depth",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "controller_queue_depth", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Actuator commands sent (per minute)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum by (actuator_id) (rate(controller_actuator_commands_sent_total[5m])) * 60",
          "legendFormat": "{{actuator_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Sensor messages received",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (sensor_id) (rate(controller_sensor_messages_received_total[5m]))",
          "legendFormat": "{{sensor_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "mps" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Broker reconnects",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "increase(controller_broker_reconnects_total[15m])",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ]
}
