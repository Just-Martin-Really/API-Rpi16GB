# Copy to .env and fill in real values. .env is gitignored.
#
# Note: the scripts use `curl -k`, which skips TLS certificate verification.
# This is intentional for the self-signed lab certificate but means the
# scripts are not safe to run against an untrusted network.

# Backend base URL.
#   From Mac on Production WLAN:  https://192.168.50.92
#   From the Pi itself:           https://localhost
BACKEND_URL=https://192.168.50.92

# Dashboard credentials (row in dashboard_users table)
DASHBOARD_USER=
DASHBOARD_PW=

# Actuator ID (single Pico in current setup)
ACTUATOR_ID=actuator01
