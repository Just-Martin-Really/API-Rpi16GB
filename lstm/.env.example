# Copy to .env and fill in. .env is gitignored.
# This file is for local-workstation development only. In production the
# values live in the lstm service block of docker/docker-compose.yml.

# ── API access ────────────────────────────────────────────────────────────────
API_BASE_URL=https://www.lab.local
API_CA_CERT=./ca.crt

# Keycloak client-credentials flow. The LSTM service authenticates as the
# `lstm-client` confidential client and uses the resulting access token to
# call the backend API.
KEYCLOAK_TOKEN_URL=https://www.lab.local/auth/realms/iot/protocol/openid-connect/token
LSTM_CLIENT_ID=lstm-client
LSTM_CLIENT_SECRET_FILE=./keycloak_lstm_secret.txt

# ── Data source ───────────────────────────────────────────────────────────────
# "api" (default), "sim", or "csv".
DATA_SOURCE=api
# Days of history to use for training and inference (capped at 7 by archiver).
API_DAYS=7

# ── Control loop ──────────────────────────────────────────────────────────────
TARGET_LOW=19.0
TARGET_HIGH=23.0
LOOKAHEAD=30
LOOP_SECONDS=60
ACTUATOR_HEATER_ID=heater01
ACTUATOR_COOLER_ID=cooler01
