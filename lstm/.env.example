# Copy to .env and fill in. .env is gitignored.
#
# PI-REBUILD: on the Pi inside the docker network, API_BASE_URL becomes
# https://nginx and API_CA_CERT becomes the mounted secret path
# /run/secrets/ca_cert (same conventions as controller.py).

# ── API access ────────────────────────────────────────────────────────────────
API_BASE_URL=https://192.168.50.92
API_CA_CERT=./ca.crt

# Service account credentials. Username matches the row seeded in init.sql.
# LSTM_PASS_FILE is a path to a file containing the password as plain text.
LSTM_USER=lstm
LSTM_PASS_FILE=./lstm_password.txt

# ── Data source ───────────────────────────────────────────────────────────────
# "api" (default), "sim", or "csv".
DATA_SOURCE=api
# Days of history to use for training and inference (capped at 7 by archiver).
API_DAYS=7

# ── Control loop ──────────────────────────────────────────────────────────────
TARGET_LOW=19.0
TARGET_HIGH=23.0
LOOKAHEAD=30
LOOP_SECONDS=60
ACTUATOR_HEATER_ID=heater01
ACTUATOR_COOLER_ID=cooler01
